# Environment Variables

# SUPABASE
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # Required for admin panel (server-only, never expose to client)

# TELEGRAM
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# APP
NEXT_PUBLIC_APP_URL=https://your-domain.com       # Used in sitemap.xml and robots.txt
